; Engine configuration for Volley Beach
; Godot 4.6.2

[application]
config/name = "Volley Beach"
config/description = "A small 2D game about 2 players locally playing volleyball."
run/main_scene = "res://Scenes/Game.tscn"
config/icon = "res://icon.svg"

[display]
window/size/viewport_width = 1920
window/size/viewport_height = 1080
window/size/mode = 2
window/size/initial_window_width = 1280
window/size/initial_window_height = 720
window/stretch/mode = "canvas_items"
window/stretch/aspect = "keep"

[input]
jump={
"deadzone": 0.5,
"events": [{"keycode": 87, "type": 0}]
}
move_left={
"deadzone": 0.5,
"events": [{"keycode": 65, "type": 0}]
}
move_right={
"deadzone": 0.5,
"events": [{"keycode": 68, "type": 0}]
}
spawn_ball_L={
"deadzone": 0.5,
"events": [{"keycode": 74, "type": 0}]
}
trigger_action_ball={
"deadzone": 0.5,
"events": [{"keycode": 69, "type": 0}]
}
arrow_jump={
"deadzone": 0.5,
"events": [{"keycode": 16777223, "type": 0}]
}
arrow_left={
"deadzone": 0.5,
"events": [{"keycode": 16777231, "type": 0}]
}
arrow_right={
"deadzone": 0.5,
"events": [{"keycode": 16777233, "type": 0}]
}
spawn_ball_R={
"deadzone": 0.5,
"events": [{"keycode": 75, "type": 0}]
}
trigger_action_ball_R={
"deadzone": 0.5,
"events": [{"keycode": 47, "type": 0}]
}

[physics]
common/enable_pause_aware_picking = true

[memory]
limits/message_queue_size_kb = 1024
